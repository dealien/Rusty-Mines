{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cargo",
            "command": "build",
            "problemMatcher": [
                "$rustc"
            ],
            "group": "build",
            "label": "rust: cargo build"
        },
        {
            "type": "shell",
            "command": "cargo fmt --all",
            "problemMatcher": [],
            "label": "rust: cargo fmt"
        },
        {
            "type": "cargo",
            "command": "clippy",
            "args": [
                "--",
                "-D",
                "warnings"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "label": "rust: cargo clippy"
        },
        {
            "type": "cargo",
            "command": "test",
            "problemMatcher": [
                "$rustc"
            ],
            "label": "rust: cargo test"
        },
        {
            "label": "Check All (lint, format, test)",
            "dependsOn": [
                "rust: cargo fmt",
                "rust: cargo clippy",
                "rust: cargo test"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
